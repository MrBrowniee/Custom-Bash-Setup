# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

#region Aliasing brave launch from command line for multiple profiles
unalias brave 2>/dev/null

brave() {
    #Initialize profile flags
    local profile_flag=()
    case "$1" in 
    --help | -h)
        cat $HOME/.bash/Help/brave_help.txt
        return
        ;;
    --main | -m)
        profile_flag=(--profile-directory="Profile 3")
        shift
        ;;
    --work | -w)
        profile_flag=(--profile-directory="Profile 4")
        shift
        ;;
    esac

    command nohup brave-browser "${profile_flag[@]}" "$@" >/dev/null 2>&1 &
    #printf "Opening Brave with $profile_flag"
}
#endregion

#region Recursively change file permissions inside current directory
fileperm() {
    local exec_flag=()
    case "$1" in
    --help | -h)
        cat $HOME/.bash/Help/fileperm_help.txt
        return
        ;;
    #Remove execution bit from everyone
    --all-x | -a-x)
        exec_flag=(-exec chmod a-x)
        shift
        ;;
    #Only owner can read and write files
    --user_rw | -u_rw)
        exec_flag=(-exec chmod 600)
        shift
        ;;
    esac
    command find . -type f "${exec_flag[@]}" -- {} +
} 
#endregion

#region Print current date when opening terminal
print_date() {
    printf "$(date '+\e[1;31m%A \e[1;36m%-d.%-m.\e[0;36m%Y') \n\e[0m"
}
#endregion

#region Reprint the date on top of terminal when clearing terminal with hotkey
__custom_clear() {
    command clear
    print_date
}
#endregion

#region Set gnome terminal title
set_title() {
    echo -ne "\033]0;$1 - $PWD\007"
}
#endregion

#region Switch to git prompt automatically
set_prompt() {
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        #Set git prompt inside git directories
        PS1="$git_prompt"
    else
        PS1="$normal_prompt"
    fi
}
#endregion

#region Make new dir > cd into new dir
mkcd() {
    mkdir "$1" && cd "$1"
}
